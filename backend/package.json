{
    "name": "daymark-backend",
    "version": "1.0.0",
    "description": "Daymark productivity platform backend with Better Auth and NestJS",
    "main": "dist/main.js",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "NODE_ENV=production node dist/main.js",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./jest-e2e.config.json",
        "prisma:generate": "prisma generate",
        "db:migrate": "prisma migrate dev && npx @better-auth/cli migrate",
        "db:migrate:prod": "prisma migrate deploy && npx @better-auth/cli migrate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "docker:up": "docker compose up --build",
        "docker:down": "docker compose down",
        "docker:dev": "NODE_ENV=development docker compose up --build",
        "docker:prod": "NODE_ENV=production docker compose up --build -d",
        "docker:logs": "docker compose logs -f backend",
        "docker:rebuild": "docker compose up --build --force-recreate"
    },
    "dependencies": {
        "@better-auth/expo": "^1.4.18",
        "@bull-board/api": "^6.16.2",
        "@bull-board/nestjs": "^6.16.2",
        "@microsoft/microsoft-graph-client": "^3.0.7",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/schedule": "^6.1.0",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/throttler": "^6.5.0",
        "@noble/hashes": "^2.0.1",
        "@thallesp/nestjs-better-auth": "^2.2.2",
        "better-auth": "^1.4.13",
        "bullmq": "^5.1.8",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "date-fns": "^4.1.0",
        "googleapis": "^169.0.0",
        "helmet": "^8.1.0",
        "ioredis": "^5.4.1",
        "isomorphic-fetch": "^3.0.0",
        "nodemailer": "^7.0.12",
        "qrcode": "^1.5.4",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "speakeasy": "^2.0.0",
        "tsdav": "^2.1.6",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^10.2.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.1.12",
        "@prisma/client": "^5.22.0",
        "@types/compression": "^1.8.1",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/node": "^20.0.0",
        "@types/nodemailer": "^7.0.5",
        "@types/qrcode": "^1.5.6",
        "@types/speakeasy": "^2.0.10",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^9.1.2",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.2.0",
        "jest-mock-extended": "^4.0.0",
        "prettier": "^3.8.1",
        "prisma": "^5.22.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.0.0"
    }
}
