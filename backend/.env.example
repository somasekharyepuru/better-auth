# ============================================================
# Daymark Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED
# ============================================================

# Better Auth secret (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Database connection (Docker - use internal service names)
DATABASE_URL=postgresql://postgres:password@postgres:5432/daymark?schema=public

# Redis connection (Docker - use internal service name)
REDIS_URL=redis://redis:6379

# Email webhook URL (N8N or similar service)
N8N_WEBHOOK_URL=

# ============================================================
# OPTIONAL
# ============================================================

# Application settings
APP_NAME=Daymark
PORT=3000
NODE_ENV=development

# Better Auth URL
BETTER_AUTH_URL=http://localhost:3002

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Mobile API key (minimum 32 characters if set)
# Generate with: openssl rand -base64 32
# Leave empty to require CSRF tokens for mobile clients
MOBILE_API_KEY=

# Mobile app deep-link host for OAuth callbacks (used in trustedOrigins as mobile://<scheme>)
# Must match the scheme registered in mobile/app.json
MOBILE_APP_SCHEME=mobile

# Email settings
MAIL_TIMEOUT_MS=10000
MAIL_MAX_RETRIES=3

# Social Providers - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Social Providers - Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend URL (for invitation & reset password links)
FRONTEND_URL=http://localhost:3000

# Better Auth base URL (if different from BETTER_AUTH_URL)
AUTH_BASE_URL=http://localhost:3002

# ============================================================
# ADMIN SEED (Optional)
# ============================================================
# Set these to automatically create an admin user on first startup
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=daymark
POSTGRES_PORT=5432

# ============================================================
# REDIS
# ============================================================
REDIS_PORT=6379

# ============================================================
# MAILHOG (Development)
# ============================================================
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================================
# DEVELOPMENT vs PRODUCTION
# ============================================================
# Development: NODE_ENV=development
# Production: NODE_ENV=production
#
# Development: Uses hot-reload, mounts source code
# Production: Uses built code, optimized image

# GA4 Measurement Protocol (optional — mobile POST /api/telemetry/ga4)
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
