# ===========================================
# AUTH-BACKEND CONFIGURATION
# ===========================================
# This file is kept for legacy compatibility.
# The canonical template is .env.example
# Copy .env.example to .env and update values.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=auth_service
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/auth_service?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Application Configuration
NODE_ENV=development
PORT=3002

# Better Auth Configuration
# CRITICAL: Generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3002
AUTH_BASE_URL=http://localhost:3002
APP_NAME=Auth Service

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Mobile API key (optional - generate with: openssl rand -base64 32)
MOBILE_API_KEY=

# OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Email (N8N webhook or compatible service)
N8N_WEBHOOK_URL=
MAIL_TIMEOUT_MS=10000
MAIL_MAX_RETRIES=3

# Frontend URL (for invitation & reset password links)
FRONTEND_URL=http://localhost:3000

# Admin User Seed (Optional - created on first startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Mailhog (Development only)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
